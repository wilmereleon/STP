title Sistema de Teleprompter - Arquitectura Completa Frontend + Backend\n**Patrón Flux/Observer + RESTful API + WebSocket**

package "Estado Centralizado (Stores)" {
  
  class TeleprompterStore {
    - state: TeleprompterState
    - listeners: Set<Listener>
    - autoScrollService: AutoScrollService
    - syncService: SyncService
    --
    + getState(): TeleprompterState
    + subscribe(listener: Listener): Unsubscribe
    + dispatch(action: TeleprompterAction): void
    --
    **Actions:**
    + play(): void
    + pause(): void
    + reset(): void
    + setSpeed(speed: number): void
    + setFontSize(size: number): void
    + setScrollPosition(position: number): void
    + setText(text: string): void
    + nextCue(): void
    + previousCue(): void
    --
    - notifyListeners(): void
    - validateSpeed(speed: number): number
    - validateFontSize(size: number): number
  }
  
  class TeleprompterState {
    + text: string
    + isPlaying: boolean
    + speed: number
    + fontSize: number
    + scrollPosition: number
    + currentScript: string
    + jumpMarkers: Map<string, number>
    + guideLinePosition: number
    + theme: 'dark' | 'light'
    + timestamp: number
  }
  
  class RunOrderStore {
    - items: RunOrderItem[]
    - currentItemId: string | null
    - listeners: Set<Listener>
    --
    + getItems(): RunOrderItem[]
    + getCurrentItem(): RunOrderItem | null
    + subscribe(listener: Listener): Unsubscribe
    + dispatch(action: RunOrderAction): void
    --
    **Actions:**
    + addItem(item: RunOrderItem): void
    + removeItem(id: string): void
    + updateItem(id: string, changes: Partial<RunOrderItem>): void
    + reorderItems(dragIndex: number, hoverIndex: number): void
    + selectItem(id: string): void
    + setItemStatus(id: string, status: ItemStatus): void
    + importFromExcel(data: ExcelData): void
    + exportToAWN(): string
  }
  
  class ConfigurationStore {
    - macros: MacroSettings
    - guideLineSettings: GuideLineSettings
    - editorSettings: EditorSettings
    - listeners: Set<Listener>
    --
    + getConfig(): Configuration
    + subscribe(listener: Listener): Unsubscribe
    + updateMacros(macros: MacroSettings): void
    + updateGuideLine(settings: GuideLineSettings): void
    + updateEditor(settings: EditorSettings): void
    + reset(): void
  }
}

package "Servicios (Services)" {
  
  class SyncService {
    - store: TeleprompterStore
    - slaves: Map<string, Window>
    - commandQueue: Command[]
    - lastSyncTimestamp: number
    --
    + registerSlave(id: string, window: Window): void
    + unregisterSlave(id: string): void
    + broadcastState(state: TeleprompterState): void
    + sendCommand(command: Command): Promise<void>
    + handleSlaveMessage(message: SlaveMessage): void
    --
    - processCommandQueue(): void
    - resolveConflict(local: State, remote: State): State
    - validateMessage(message: Message): boolean
  }
  
  class Command {
    + id: string
    + type: CommandType
    + payload: any
    + timestamp: number
    + sourceId: string
    + requiresAck: boolean
    --
    + execute(): void
    + undo(): void
  }
  
  enum CommandType {
    PLAY
    PAUSE
    RESET
    SET_SPEED
    SET_FONT_SIZE
    SET_SCROLL_POSITION
    SET_TEXT
    SYNC_STATE
  }
  
  class AutoScrollService {
    - store: TeleprompterStore
    - intervalId: number | null
    - lastUpdateTime: number
    - targetFPS: number = 60
    --
    + start(): void
    + stop(): void
    + pause(): void
    + resume(): void
    + setSpeed(speed: number): void
    --
    - tick(): void
    - calculateIncrement(deltaTime: number, speed: number): number
    - detectEndOfText(): boolean
    - handleAutoAdvance(): void
  }
  
  class PersistenceService {
    - fs: typeof import('fs')
    - path: typeof import('path')
    - userDataPath: string
    - autoSaveInterval: number = 30000
    - lastSaveTime: number
    --
    + initialize(): Promise<void>
    + saveScripts(items: RunOrderItem[]): Promise<void>
    + loadScripts(): Promise<RunOrderItem[]>
    + saveConfig(config: Configuration): Promise<void>
    + loadConfig(): Promise<Configuration>
    + loadTextFile(filePath: string): Promise<string>
    + saveTextFile(filePath: string, content: string): Promise<void>
    + exportSession(outputPath: string): Promise<void>
    + importSession(filePath: string): Promise<void>
    + enableAutoSave(): void
    + disableAutoSave(): void
    --
    - ensureDirectory(dirPath: string): Promise<void>
    - getConfigPath(): string
    - getScriptsPath(): string
  }
  
  note right of PersistenceService
    <b>Electron Local Storage</b>
    Usa fs (file system) de Node.js
    No IndexedDB (eso es para web)
    
    Rutas típicas:
    - Windows: C:\\Users\\[user]\\AppData\\Roaming\\Teleprompter Pro\\
    - macOS: ~/Library/Application Support/Teleprompter Pro/
    - Linux: ~/.config/Teleprompter Pro/
    
    Archivos:
    - config.json (configuración)
    - scripts.json (run order)
    - [nombre].txt (scripts individuales)
  end note
  
  class ExcelImportService {
    - fs: typeof import('fs')
    --
    + importFromFile(filePath: string): Promise<RunOrderItem[]>
    + importFromBuffer(buffer: ArrayBuffer): Promise<RunOrderItem[]>
    + validateExcelData(data: any[][]): ValidationResult
    + mapExcelToRunOrder(data: any[][]): RunOrderItem[]
    + previewImport(filePath: string): Promise<PreviewData>
    --
    - detectColumns(headers: string[]): ColumnMapping
    - parseRowToItem(row: any[], mapping: ColumnMapping): RunOrderItem
  }
  
  note right of ExcelImportService
    <b>Lectura de Excel Local</b>
    Lee archivos .xlsx del sistema de archivos
    usando biblioteca 'xlsx' (SheetJS)
    
    Soporta:
    - Ruta absoluta: C:\\path\\to\\file.xlsx
    - Diálogo de Electron para seleccionar archivo
    - Buffer directo desde fs.readFile()
  end note
}

package "🌐 Backend - API REST (Node.js + Express)" {
  
  class AuthController {
    - userService: UserService
    - jwtService: JWTService
    --
    + register(req, res): Promise<void>
    + login(req, res): Promise<void>
    + logout(req, res): Promise<void>
    + refresh(req, res): Promise<void>
    + me(req, res): Promise<void>
    --
    POST /api/auth/register
    POST /api/auth/login
    POST /api/auth/logout
    POST /api/auth/refresh
    GET /api/auth/me
  }
  
  class ScriptController {
    - scriptService: ScriptService
    --
    + list(req, res): Promise<void>
    + create(req, res): Promise<void>
    + getById(req, res): Promise<void>
    + update(req, res): Promise<void>
    + delete(req, res): Promise<void>
    + duplicate(req, res): Promise<void>
    + search(req, res): Promise<void>
    --
    GET /api/scripts
    POST /api/scripts
    GET /api/scripts/:id
    PUT /api/scripts/:id
    DELETE /api/scripts/:id
    POST /api/scripts/:id/duplicate
  }
  
  class RunOrderController {
    - runOrderService: RunOrderService
    --
    + list(req, res): Promise<void>
    + create(req, res): Promise<void>
    + getById(req, res): Promise<void>
    + update(req, res): Promise<void>
    + delete(req, res): Promise<void>
    + addItem(req, res): Promise<void>
    + removeItem(req, res): Promise<void>
    + activate(req, res): Promise<void>
    --
    GET /api/runorders
    POST /api/runorders
    GET /api/runorders/:id
    PUT /api/runorders/:id
    POST /api/runorders/:id/items
    DELETE /api/runorders/:id/items/:itemId
  }
  
  class ConfigController {
    - configService: ConfigService
    --
    + get(req, res): Promise<void>
    + update(req, res): Promise<void>
    + reset(req, res): Promise<void>
    + changeTheme(req, res): Promise<void>
    --
    GET /api/config
    PUT /api/config
    POST /api/config/reset
    PATCH /api/config/theme
  }
  
  class MacroController {
    - macroService: MacroService
    --
    + list(req, res): Promise<void>
    + create(req, res): Promise<void>
    + update(req, res): Promise<void>
    + delete(req, res): Promise<void>
    + restoreDefaults(req, res): Promise<void>
    + toggle(req, res): Promise<void>
    --
    GET /api/macros
    POST /api/macros
    PUT /api/macros/:id
    DELETE /api/macros/:id
    POST /api/macros/defaults
  }
}

package "📦 Backend - Mongoose Models" {
  
  class UserModel {
    + _id: ObjectId
    + email: string (unique)
    + password: string (hashed)
    + name: string
    + role: 'Admin' | 'Producer' | 'Operator'
    + isActive: boolean
    + lastLogin: Date
    + preferences: JSON
    + createdAt: Date
    + updatedAt: Date
    --
    + comparePassword(password): Promise<boolean>
    + getPublicProfile(): UserPublic
    --
    <i>Hooks:</i>
    pre-save: hash password con bcrypt
    --
    <i>Statics:</i>
    findByEmail(email): Promise<User>
  }
  
  class ScriptModel {
    + _id: ObjectId
    + userId: ObjectId (ref: User)
    + title: string
    + content: string
    + metadata: JSON
    + deletedAt: Date | null
    + createdAt: Date
    + updatedAt: Date
    --
    <i>Indexes:</i>
    { userId, deletedAt }
    { title: 'text', content: 'text' }
  }
  
  class RunOrderModel {
    + _id: ObjectId
    + userId: ObjectId (ref: User)
    + title: string
    + description: string
    + isActive: boolean
    + runOrderItems: [RunOrderItemSchema]
    + totalDuration: number
    + createdAt: Date
    + updatedAt: Date
    --
    <i>Embedded Schema - RunOrderItemSchema:</i>
    scriptId: ObjectId (ref: Script)
    position: number
    duration: number
    --
    <i>Hooks:</i>
    pre-save: calcular totalDuration
    pre-save: validar solo 1 activo
    --
    <i>Virtuals:</i>
    itemCount: runOrderItems.length
  }
  
  class ConfigurationModel {
    + _id: ObjectId
    + userId: ObjectId (ref: User, unique)
    + fontSize: number (12-120)
    + fontFamily: string
    + textColor: string (hex)
    + backgroundColor: string (hex)
    + scrollSpeed: number (1-100)
    + guidelinePosition: number (0-100)
    + guidelineColor: string (hex)
    + guidelineThickness: number (1-10)
    + showGuideline: boolean
    + mirrorMode: boolean
    + autoSave: boolean
    + theme: 'light' | 'dark'
    + createdAt: Date
    + updatedAt: Date
    --
    <i>Validaciones:</i>
    fontSize: 12-120, scrollSpeed: 1-100
    colores: regex /^#[0-9A-F]{6}$/
  }
  
  class MacroModel {
    + _id: ObjectId
    + userId: ObjectId (ref: User)
    + key: string (ej: 'F11', 'Ctrl+P')
    + action: string
    + category: 'Playback' | 'Navigation' | ...
    + description: string
    + isEnabled: boolean
    + createdAt: Date
    + updatedAt: Date
    --
    <i>Indexes:</i>
    { userId, key } (unique compound)
  }
  
  class SessionModel {
    + _id: ObjectId
    + userId: ObjectId (ref: User)
    + token: string (JWT, indexed)
    + expiresAt: Date
    + isActive: boolean
    + ipAddress: string
    + userAgent: string
    + createdAt: Date
    --
    <i>Statics:</i>
    createSession(userId, token, ...)
    invalidateSession(token)
  }
  
  class AuditLogModel {
    + _id: ObjectId
    + entityType: 'User' | 'Script' | ...
    + entityId: ObjectId
    + action: 'create' | 'update' | ...
    + userId: ObjectId (ref: User)
    + changes: Mixed
    + ipAddress: string
    + userAgent: string
    + createdAt: Date
    --
    <i>Statics:</i>
    logChange(entityType, entityId, ...)
  }
}

package "🔌 Backend - WebSocket (Socket.IO)" {
  
  class WebSocketServer {
    - io: SocketIO.Server
    - activeConnections: Map<string, Connection>
    --
    + on('connection', handler): void
    + broadcast(event, data): void
    + emitToUser(userId, event, data): void
    --
    <i>Events emitidos:</i>
    - sync:teleprompter
    - sync:runorder
    - script:updated
    - script:created
    - script:deleted
  }
  
  class Connection {
    + socketId: string
    + userId: string
    + role: 'operator' | 'producer'
    + connectedAt: Date
  }
}

package "🛡️ Backend - Middlewares" {
  
  class AuthMiddleware {
    + authenticateToken(req, res, next): void
    + requireRole(roles: string[]): Middleware
    + requireAdmin(req, res, next): void
    --
    Verifica JWT en header Authorization
    Valida sesión activa en DB
    Agrega req.user con {userId, email, role}
  }
  
  class RateLimitMiddleware {
    + apiLimiter: RateLimiter (100 req/15min)
    + authLimiter: RateLimiter (5 req/15min)
    + createLimiter: RateLimiter (20 req/hora)
  }
  
  class ErrorMiddleware {
    + errorHandler(err, req, res, next): void
    + notFoundHandler(req, res, next): void
    --
    Maneja:
    - ValidationError (400)
    - CastError (400)
    - Duplicate key (409)
    - JWT errors (401)
    - Generic errors (500)
  }
}

package "🔗 Frontend - API Client" {
  
  class ApiClient {
    - baseURL: string = 'http://localhost:3000'
    - token: string | null
    --
    + setToken(token: string): void
    + clearToken(): void
    --
    <i>Auth endpoints:</i>
    + login(email, password): Promise<LoginResponse>
    + register(data): Promise<User>
    + logout(): Promise<void>
    + refresh(refreshToken): Promise<string>
    --
    <i>Script endpoints:</i>
    + getScripts(params): Promise<Script[]>
    + createScript(data): Promise<Script>
    + updateScript(id, data): Promise<Script>
    + deleteScript(id): Promise<void>
    --
    <i>RunOrder endpoints:</i>
    + getRunOrders(): Promise<RunOrder[]>
    + createRunOrder(data): Promise<RunOrder>
    + addItemToRunOrder(id, item): Promise<void>
    --
    Interceptor: agrega token a headers
    Manejo de errores 401 → refresh token
  }
  
  class WebSocketClient {
    - socket: Socket
    - store: TeleprompterStore
    --
    + connect(): void
    + disconnect(): void
    + identify(userId, role): void
    + emit(event, data): void
    + on(event, handler): void
    --
    <i>Events escuchados:</i>
    - sync:teleprompter → actualiza store
    - sync:runorder → actualiza store
    - script:updated → refresca lista
  }
}

package "Interfaces de Datos" {
  
  class RunOrderItem {
    + id: string
    + title: string
    + text: string
    + duration: string
    + status: ItemStatus
    + notes?: string
    + createdAt: Date
    + updatedAt: Date
  }
  
  enum ItemStatus {
    READY
    PLAYING
    COMPLETED
  }
  
  class MacroSettings {
    + playStop: string
    + pause: string
    + previous: string
    + next: string
    + increaseSpeed: string
    + decreaseSpeed: string
    + increaseFontSize: string
    + decreaseFontSize: string
    + nextCue?: string
    + previousCue?: string
  }
  
  class EditorSettings {
    + enableRichText: boolean
    + showLineNumbers: boolean
    + fontSize: number
    + theme: 'light' | 'dark'
    + spellCheck: boolean
  }
}

package "Hooks Personalizados" {
  
  class useTeleprompterStore <<hook>> {
    + store: TeleprompterStore
    + state: TeleprompterState
    --
    + play(): void
    + pause(): void
    + reset(): void
    + setSpeed(speed: number): void
    + setFontSize(size: number): void
    --
    Usa subscribe() y causa re-render
    automático cuando cambia el estado
  }
  
  class useAutoScroll <<hook>> {
    + isScrolling: boolean
    + scrollPosition: number
    --
    + start(): void
    + stop(): void
    --
    Hook que conecta con AutoScrollService
    y sincroniza el scroll del DOM
  }
  
  class usePersistence <<hook>> {
    + isSaving: boolean
    + lastSaved: Date | null
    --
    + save(): Promise<void>
    + load(): Promise<void>
    + enableAutoSave(): void
    --
    Hook que maneja persistencia automática
  }
}

