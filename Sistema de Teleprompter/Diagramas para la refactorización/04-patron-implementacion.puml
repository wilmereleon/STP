package "💻 FRONTEND - PASO 7: WebSocket Client" {
  class FrontendWebSocket {
    <b>Archivo:</b> src/services/WebSocketClient.ts
    --
    <i>Socket.IO Client:</i>
    --
    <b>Inicialización:</b>
    socket = io('http://localhost:3001', {
      auth: { token: jwt },
      reconnection: true,
      reconnectionDelay: 1000
    })
    --
    <b>Eventos escuchados:</b>
    on('connect', () => {
      socket.emit('identify', {userId, role})
    })
    --
    on('sync:teleprompter', (state) => {
      store.applyRemoteState(state)
    })
    --
    on('script:updated', (script) => {
      store.updateScript(script)
      toast.info('Script actualizado')
    })
    --
    <b>Integración con Store:</b>
    useEffect(() =>
      wsClient.connect()
      wsClient.onStateSync((state) =>
        if (state.timestamp > localState.timestamp)
          applyState(state)
      )
    )
  }
}

package "💻 FRONTEND - PASO 8: Integración Stores ↔ API" {
  class StoreAPIIntegration {
    <b>Archivo:</b> src/stores/TeleprompterStore.ts
    --
    <i>Persistencia automática:</i>
    --
    <b>Patrón:</b>
    1. Usuario cambia estado local
    2. Store notifica componentes (rápido)
    3. Store llama API en background
    4. API actualiza backend
    5. Backend broadcast WebSocket
    6. Otros clientes reciben update
    --
    <b>Ejemplo - Cambio de velocidad:</b>
    setSpeed(speed)
      1. Update local
      this.state.speed = speed
      this.notifyListeners()
      
      2. Persist to backend (async)
      apiClient.updateConfig(scrollSpeed: speed)
        .catch(err =>
          Rollback on error
          this.state.speed = oldSpeed
          this.notifyListeners()
          toast.error('Error al guardar')
        )
      
      3. Broadcast local (popup)
      syncService.broadcast(this.state)
      
      4. Broadcast network (WebSocket)
      wsClient.emit('sync:teleprompter', speed)
    --
    <b>Ventajas:</b>
    ✓ UI responsive (no espera API)
    ✓ Persistencia en background
    ✓ Rollback automático en error
    ✓ Sincronización multi-nivel
  }
}

package "🔐 SEGURIDAD - PASO 9: Autenticación" {
  class AuthFlow {
    <b>Flujo completo:</b>
    --
    <b>1. Register/Login</b>
    POST /api/auth/login
    → Backend valida credenciales
    → Genera JWT access token (1h)
    → Genera refresh token (7d)
    → Crea Session en DB
    → Retorna tokens + user
    --
    <b>2. Frontend guarda tokens</b>
    localStorage.setItem('accessToken', ...)
    localStorage.setItem('refreshToken', ...)
    --
    <b>3. Requests autenticados</b>
    headers: Authorization: Bearer + accessToken
    --
    <b>4. Token expira (401)</b>
    Interceptor detecta 401
    → POST /api/auth/refresh
    → Backend valida refreshToken
    → Genera nuevo accessToken
    → Retry request original
    --
    <b>5. WebSocket auth</b>
    socket = io(url, auth: token: accessToken)
    → Backend verifica en handshake
    → Asocia socket con userId
  }
}

